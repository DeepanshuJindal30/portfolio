<svg xmlns="http://www.w3.org/2000/svg" width="360" height="780" viewBox="0 0 360 780">
  <rect width="360" height="780" fill="#0f172a"/>
  <rect x="0" y="0" width="360" height="60" fill="#1e1b4b"/>
  <text x="24" y="38" fill="#f8fafc" font-family="system-ui" font-size="18" font-weight="bold">Upload Prescription</text>
  <rect x="24" y="100" width="312" height="200" rx="16" fill="#1e293b" stroke="#334155" stroke-width="2" stroke-dasharray="8"/>
  <text x="180" y="190" text-anchor="middle" fill="#64748b" font-family="system-ui" font-size="14">Tap to upload prescription</text>
  <text x="180" y="215" text-anchor="middle" fill="#475569" font-family="system-ui" font-size="12">JPG, PNG up to 5MB</text>
  <text x="24" y="340" fill="#f8fafc" font-family="system-ui" font-size="14" font-weight="bold">Or take a photo</text>
  <rect x="24" y="360" width="312" height="48" rx="24" fill="#1e293b"/>
  <text x="130" y="390" fill="#94a3b8" font-family="system-ui" font-size="14">Open Camera</text>
  <rect x="24" y="650" width="312" height="52" rx="26" fill="#f97316"/>
  <text x="120" y="682" fill="white" font-family="system-ui" font-size="16" font-weight="bold">Submit Prescription</text>
</svg>
